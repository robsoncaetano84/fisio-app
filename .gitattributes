# Normalize line endings and keep text files as UTF-8 in working tree
* text=auto eol=lf

# Source files
*.ts text working-tree-encoding=UTF-8
*.tsx text working-tree-encoding=UTF-8
*.js text working-tree-encoding=UTF-8
*.jsx text working-tree-encoding=UTF-8
*.json text working-tree-encoding=UTF-8
*.md text working-tree-encoding=UTF-8
*.yml text working-tree-encoding=UTF-8
*.yaml text working-tree-encoding=UTF-8
*.sql text working-tree-encoding=UTF-8
*.env text working-tree-encoding=UTF-8
*.sh text working-tree-encoding=UTF-8
*.ps1 text working-tree-encoding=UTF-8

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
