{
  "expo": {
    "name": "Synap",
    "slug": "synap",
    "scheme": "synap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/synap-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/synap-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "10000",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Permita acesso ao microfone para transcrever sua fala.",
        "NSSpeechRecognitionUsageDescription": "Permita o reconhecimento de voz para transcricao."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/synap-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 10000,
      "package": "com.anonymous.mobile"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-notifications",
        {
          "icon": "./assets/synap-logo.png",
          "color": "#2D8C6F"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permita acesso ao microfone para transcrever sua fala.",
          "speechRecognitionPermission": "Permita o reconhecimento de voz para transcricao.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "expo-font"
    ],
    "web": {
      "favicon": "./assets/synap-icon.png"
    }
  }
}
