{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "check:encoding": "node ../../scripts/check-encoding.mjs src",
    "check:i18n": "node scripts/check-i18n-consistency.mjs src/i18n/locales",
    "validate:critical": "npm run check:encoding && npm run check:i18n && npx tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.11.0",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "axios": "^1.17.0",
    "expo": "~54.0.32",
    "expo-constants": "^18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "^0.32.16",
    "expo-sharing": "~14.0.8",
    "expo-speech-recognition": "3.1.3",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  },
  "private": true
}
