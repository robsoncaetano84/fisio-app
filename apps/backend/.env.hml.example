NODE_ENV=production
PORT=3000

DB_HOST=SEU_HOST_HML
DB_PORT=5432
DB_USERNAME=SEU_USUARIO_HML
DB_PASSWORD=SUA_SENHA_HML
DB_DATABASE=fisio_hml
DB_MIGRATIONS_RUN=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=8
DB_POOL_MIN=0
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_POOL_CONNECTION_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=30000

# Gere JWT_SECRET, REFRESH_SECRET e INVITE_SECRET com:
# npm run secrets:render
JWT_SECRET=COLE_AQUI_O_VALOR_JWT_SECRET_GERADO
JWT_EXPIRES_IN=7d
REFRESH_SECRET=COLE_AQUI_O_VALOR_REFRESH_SECRET_GERADO
REFRESH_EXPIRES_IN=30d

INVITE_SECRET=COLE_AQUI_O_VALOR_INVITE_SECRET_GERADO
PATIENT_INVITE_BASE_URL=https://hml.seudominio.com/cadastro-paciente

CORS_ORIGIN=http://localhost:8081,https://hml.seudominio.com
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
TRUST_PROXY=true
APP_VERSION=0.0.0-hml
CONSENT_TERMS_VERSION=terms-hml-2026-06-07
CONSENT_PRIVACY_VERSION=privacy-hml-2026-06-07
CONSENT_RESEARCH_VERSION=research-hml-2026-06-07
CONSENT_AI_VERSION=ai-hml-2026-06-07
CONSENT_PROFESSIONAL_LGPD_VERSION=professional-lgpd-hml-2026-06-07

THROTTLE_TTL=60
THROTTLE_LIMIT=60
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MIN=15
LOCKOUT_DURATION_MIN=30
REDIS_URL=

ALLOW_ADMIN_REGISTRATION=false
MASTER_ADMIN_EMAILS=master@teste.com,master@seudominio.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_LAUDO_MODEL=gpt-5.5
OPENAI_EXAM_MODEL=gpt-5.4-mini
OPENAI_ATIVIDADE_MODEL=gpt-5.4-mini
OPENAI_CHARLES_MODEL=gpt-5.5
OPENAI_EXAM_AI_ENABLED=true
OPENAI_CHARLES_AI_ENABLED=true
OPENAI_LAUDO_TIMEOUT_MS=15000
OPENAI_EXAM_TIMEOUT_MS=30000
OPENAI_ATIVIDADE_TIMEOUT_MS=8000
OPENAI_CHARLES_TIMEOUT_MS=12000
EXPO_ACCESS_TOKEN=

SENTRY_REQUIRED=false
SENTRY_DSN=

SUPABASE_URL=https://SEU-PROJETO-HML.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_HML
SUPABASE_STORAGE_BUCKET=paciente-exames
