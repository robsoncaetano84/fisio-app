CORS_ORIGIN=https://app.seudominio.com,https://crm.seudominio.com
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
TRUST_PROXY=true
APP_VERSION=1.0.0

THROTTLE_TTL=60
THROTTLE_LIMIT=60
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MIN=15
LOCKOUT_DURATION_MIN=30
REDIS_URL=

ALLOW_ADMIN_REGISTRATION=false
