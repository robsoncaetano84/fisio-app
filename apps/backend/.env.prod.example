NODE_ENV=production
PORT=3000

DB_HOST=SEU_HOST_PROD
DB_PORT=5432
DB_USERNAME=SEU_USUARIO_PROD
DB_PASSWORD=SUA_SENHA_PROD
DB_DATABASE=fisio_prod
DB_MIGRATIONS_RUN=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

JWT_SECRET=PROD_JWT_SECRET_MUITO_FORTE
JWT_EXPIRES_IN=7d
REFRESH_SECRET=PROD_REFRESH_SECRET_MUITO_FORTE
REFRESH_EXPIRES_IN=30d

INVITE_SECRET=PROD_INVITE_SECRET_MUITO_FORTE
