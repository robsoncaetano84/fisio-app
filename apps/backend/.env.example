NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fisio_app
DB_MIGRATIONS_RUN=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRES_IN=7d
REFRESH_SECRET=troque-por-um-refresh-secret-forte
REFRESH_EXPIRES_IN=30d

INVITE_SECRET=
PATIENT_INVITE_BASE_URL=fisioapp://cadastro-paciente

CORS_ORIGIN=http://localhost:8081
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
TRUST_PROXY=false
APP_VERSION=

THROTTLE_TTL=60
THROTTLE_LIMIT=60
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MIN=15
LOCKOUT_DURATION_MIN=30
REDIS_URL=

COMMUNITY_WEB_URL=http://localhost:3002
COMMUNITY_COOKIE_DOMAIN=
COMMUNITY_SESSION_COOKIE_MAX_AGE_MS=604800000
COMMUNITY_S3_BUCKET=
COMMUNITY_S3_REGION=us-east-1
COMMUNITY_S3_ENDPOINT=
COMMUNITY_S3_PUBLIC_BASE_URL=
COMMUNITY_S3_ACCESS_KEY_ID=
COMMUNITY_S3_SECRET_ACCESS_KEY=
COMMUNITY_AI_MODEL=
COMMUNITY_AI_TIMEOUT_MS=8000

ALLOW_ADMIN_REGISTRATION=false
MASTER_ADMIN_EMAILS=master@teste.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_LAUDO_MODEL=gpt-5.5
OPENAI_EXAM_MODEL=gpt-5.4-mini
OPENAI_ATIVIDADE_MODEL=gpt-5.4-mini
OPENAI_CHARLES_MODEL=gpt-5.5
OPENAI_EXAM_AI_ENABLED=true
OPENAI_CHARLES_AI_ENABLED=true
OPENAI_LAUDO_TIMEOUT_MS=15000
OPENAI_EXAM_TIMEOUT_MS=30000
OPENAI_ATIVIDADE_TIMEOUT_MS=8000
OPENAI_CHARLES_TIMEOUT_MS=12000
EXPO_ACCESS_TOKEN=

SENTRY_DSN=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# ATENCAO: os buckets abaixo NAO sao criados automaticamente. Ao criar um novo
# projeto Supabase, crie-os manualmente no Storage:
#  - paciente-exames: PRIVADO (fotos clinicas/exames = dado sensivel de saude;
#    o backend acessa via service role key). Sem ele, upload de foto da 502
#    "Bucket not found".
#  - exercicios: publico (imagens do catalogo de exercicios).
SUPABASE_STORAGE_BUCKET=paciente-exames
SUPABASE_EXERCISE_BUCKET=exercicios
