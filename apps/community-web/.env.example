# ==========================================
# community-web — variaveis de ambiente
# ==========================================

# --- Desenvolvimento local (backend em localhost:3001) ---
# COMMUNITY_API_URL=http://localhost:3001/api
# NEXT_PUBLIC_COMMUNITY_API_URL=http://localhost:3001/api
# NEXT_PUBLIC_COMMUNITY_URL=http://localhost:3002

# --- Producao no Render (*.onrender.com, SEM dominio proprio) ---
# onrender.com esta na Public Suffix List: front e backend em subdominios
# distintos sao "sites" diferentes, e o cookie de sessao (SameSite=Lax)
# NAO funciona cross-site. Por isso o navegador deve falar apenas com o
# proprio front (NEXT_PUBLIC_COMMUNITY_API_URL=/api) e o next.config.js
# proxia /api/* para o backend via rewrite (COMMUNITY_API_URL).
# IMPORTANTE: nesse cenario, NAO setar COMMUNITY_COOKIE_DOMAIN no backend.
#
# COMMUNITY_API_URL=https://fisio-backend-pax6.onrender.com/api
# NEXT_PUBLIC_COMMUNITY_API_URL=/api
# NEXT_PUBLIC_COMMUNITY_URL=https://<este-servico>.onrender.com
#
# No BACKEND (Render), apontar de volta para este front:
# COMMUNITY_WEB_URL=https://<este-servico>.onrender.com

# --- Producao com dominio proprio (migracao futura) ---
# Com front e API sob o mesmo dominio pai (ex.: comunidade.exemplo.com +
# api.exemplo.com), o proxy continua funcionando, mas tambem e possivel
# voltar a chamadas diretas + COMMUNITY_COOKIE_DOMAIN=.exemplo.com.
