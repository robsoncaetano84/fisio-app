ublic' AND "cl"."relname" = 'atividade_checkins') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'atividades') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'push_tokens') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'crm_tasks') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'pacientes')) ) "con" INNER JOIN "pg_attribute" "att" ON "att"."attrelid" = "con"."confrelid" AND "att"."attnum" = "con"."child" INNER JOIN "pg_class" "cl" ON "cl"."oid" = "con"."confrelid"  AND "cl"."relispartition" = 'f'INNER JOIN "pg_namespace" "ns" ON "cl"."relnamespace" = "ns"."oid" INNER JOIN "pg_attribute" "att2" ON "att2"."attrelid" = "con"."conrelid" AND "att2"."attnum" = "con"."parent"
