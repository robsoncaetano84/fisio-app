query: SELECT columns.*, pg_catalog.col_description(('"' || table_catalog || '"."' || table_schema || '"."' || table_name || '"')::regclass::oid, ordinal_position) AS description, ('"' || "udt_schema" || '"."' || "udt_name" || '"')::"regtype"::text AS "regtype", pg_catalog.format_type("col_attr"."atttypid", "col_attr"."atttypmod") AS "format_type" FROM "information_schema"."columns" LEFT JOIN "pg_catalog"."pg_attribute" AS "col_attr" ON "col_attr"."attname" = "columns"."column_name" AND "col_attr"."attrelid" = ( SELECT "cls"."oid" FROM "pg_catalog"."pg_class" AS "cls" LEFT JOIN "pg_catalog"."pg_namespace" AS "ns" ON "ns"."oid" = "cls"."relnamespace" WHERE "cls"."relname" = "columns"."table_name" AND "ns"."nspname" = "columns"."table_schema" ) WHERE ("table_schema" = 'public' AND "table_name" = 'laudo_ai_generations') OR ("table_schema" = 'public' AND "table_name" = 'auth_logs') OR ("table_schema" = 'public' AND "table_name" = 'crm_leads') OR ("table_schema" = 'public' AND "table_name" = 'laudos') OR ("table_schema" = 'public' AND "table_name" = 'paciente_exames') OR ("table_schema" = 'public' AND "table_name" = 'crm_interactions') OR ("table_schema" = 'public' AND "table_name" = 'anamneses') OR ("table_schema" = 'public' AND "table_name" = 'usuarios') OR ("table_schema" = 'public' AND "table_name" = 'evolucoes') OR ("table_schema" = 'public' AND "table_name" = 'atividade_checkins') OR ("table_schema" = 'public' AND "table_name" = 'atividades') OR ("table_schema" = 'public' AND "table_name" = 'push_tokens') OR ("table_schema" = 'public' AND "table_name" = 'crm_tasks') OR ("table_schema" = 'public' AND "table_name" = 'pacientes')
query: SELECT "ns"."nspname" AS "table_schema", "t"."relname" AS "table_name", "cnst"."conname" AS "constraint_name", pg_get_constraintdef("cnst"."oid") AS "expression", CASE "cnst"."contype" WHEN 'p' THEN 'PRIMARY' WHEN 'u' THEN 'UNIQUE' WHEN 'c' THEN 'CHECK' WHEN 'x' THEN 'EXCLUDE' END AS "constraint_type", "a"."attname" AS "column_name" FROM "pg_constraint" "cnst" INNER JOIN "pg_class" "t" ON "t"."oid" = "cnst"."conrelid" INNER JOIN "pg_namespace" "ns" ON "ns"."oid" = "cnst"."connamespace" LEFT JOIN "pg_attribute" "a" ON "a"."attrelid" = "cnst"."conrelid" AND "a"."attnum" = ANY ("cnst"."conkey") WHERE "t"."relkind" IN ('r', 'p') AND (("ns"."nspname" = 'public' AND "t"."relname" = 'laudo_ai_generations') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'auth_logs') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'crm_leads') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'laudos') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'paciente_exames') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'crm_interactions') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'anamneses') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'usuarios') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'evolucoes') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'atividade_checkins') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'atividades') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'push_tokens') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'crm_tasks') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'pacientes'))
query: SELECT "ns"."nspname" AS "table_schema", "t"."relname" AS "table_name", "i"."relname" AS "constraint_name", "a"."attname" AS "column_name", CASE "ix"."indisunique" WHEN 't' THEN 'TRUE' ELSE'FALSE' END AS "is_unique", pg_get_expr("ix"."indpred", "ix"."indrelid") AS "condition", "types"."typname" AS "type_name", "am"."amname" AS "index_type" FROM "pg_class" "t" INNER JOIN "pg_index" "ix" ON "ix"."indrelid" = "t"."oid" INNER JOIN "pg_attribute" "a" ON "a"."attrelid" = "t"."oid"  AND "a"."attnum" = ANY ("ix"."indkey") INNER JOIN "pg_namespace" "ns" ON "ns"."oid" = "t"."relnamespace" INNER JOIN "pg_class" "i" ON "i"."oid" = "ix"."indexrelid" INNER JOIN "pg_type" "types" ON "types"."oid" = "a"."atttypid" INNER JOIN "pg_am" "am" ON "i"."relam" = "am"."oid" LEFT JOIN "pg_constraint" "cnst" ON "cnst"."conname" = "i"."relname" WHERE "t"."relkind" IN ('r', 'p') AND "cnst"."contype" IS NULL AND (("ns"."nspname" = 'public' AND "t"."relname" = 'laudo_ai_generations') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'auth_logs') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'crm_leads') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'laudos') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'paciente_exames') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'crm_interactions') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'anamneses') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'usuarios') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'evolucoes') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'atividade_checkins') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'atividades') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'push_tokens') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'crm_tasks') OR ("ns"."nspname" = 'public' AND "t"."relname" = 'pacientes'))
query: SELECT "con"."conname" AS "constraint_name", "con"."nspname" AS "table_schema", "con"."relname" AS "table_name", "att2"."attname" AS "column_name", "ns"."nspname" AS "referenced_table_schema", "cl"."relname" AS "referenced_table_name", "att"."attname" AS "referenced_column_name", "con"."confdeltype" AS "on_delete", "con"."confupdtype" AS "on_update", "con"."condeferrable" AS "deferrable", "con"."condeferred" AS "deferred" FROM ( SELECT UNNEST ("con1"."conkey") AS "parent", UNNEST ("con1"."confkey") AS "child", "con1"."confrelid", "con1"."conrelid", "con1"."conname", "con1"."contype", "ns"."nspname", "cl"."relname", "con1"."condeferrable", CASE WHEN "con1"."condeferred" THEN 'INITIALLY DEFERRED' ELSE 'INITIALLY IMMEDIATE' END as condeferred, CASE "con1"."confdeltype" WHEN 'a' THEN 'NO ACTION' WHEN 'r' THEN 'RESTRICT' WHEN 'c' THEN 'CASCADE' WHEN 'n' THEN 'SET NULL' WHEN 'd' THEN 'SET DEFAULT' END as "confdeltype", CASE "con1"."confupdtype" WHEN 'a' THEN 'NO ACTION' WHEN 'r' THEN 'RESTRICT' WHEN 'c' THEN 'CASCADE' WHEN 'n' THEN 'SET NULL' WHEN 'd' THEN 'SET DEFAULT' END as "confupdtype" FROM "pg_class" "cl" INNER JOIN "pg_namespace" "ns" ON "cl"."relnamespace" = "ns"."oid" INNER JOIN "pg_constraint" "con1" ON "con1"."conrelid" = "cl"."oid" WHERE "con1"."contype" = 'f' AND (("ns"."nspname" = 'public' AND "cl"."relname" = 'laudo_ai_generations') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'auth_logs') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'crm_leads') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'laudos') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'paciente_exames') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'crm_interactions') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'anamneses') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'usuarios') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'evolucoes') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'atividade_checkins') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'atividades') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'push_tokens') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'crm_tasks') OR ("ns"."nspname" = 'public' AND "cl"."relname" = 'pacientes')) ) "con" INNER JOIN "pg_attribute" "att" ON "att"."attrelid" = "con"."confrelid" AND "att"."attnum" = "con"."child" INNER JOIN "pg_class" "cl" ON "cl"."oid" = "con"."confrelid"  AND "cl"."relispartition" = 'f'INNER JOIN "pg_namespace" "ns" ON "cl"."relnamespace" = "ns"."oid" INNER JOIN "pg_attribute" "att2" ON "att2"."attrelid" = "con"."conrelid" AND "att2"."attnum" = "con"."parent"
