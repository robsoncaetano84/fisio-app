query: SELECT "table_schema", "table_name", obj_description(('"' || "table_schema" || '"."' || "table_name" || '"')::regclass, 'pg_class') AS table_comment FROM "information_schema"."tables" WHERE ("table_schema" = 'public' AND "table_name" = 'usuarios') OR ("table_schema" = 'public' AND "table_name" = 'pacientes') OR ("table_schema" = 'public' AND "table_name" = 'anamneses') OR ("table_schema" = 'public' AND "table_name" = 'evolucoes') OR ("table_schema" = 'public' AND "table_name" = 'laudos') OR ("table_schema" = 'public' AND "table_name" = 'laudo_ai_generations') OR ("table_schema" = 'public' AND "table_name" = 'auth_logs') OR ("table_schema" = 'public' AND "table_name" = 'atividade_checkins') OR ("table_schema" = 'public' AND "table_name" = 'atividades') OR ("table_schema" = 'public' AND "table_name" = 'push_tokens') OR ("table_schema" = 'public' AND "table_name" = 'crm_leads') OR ("table_schema" = 'public' AND "table_name" = 'crm_tasks') OR ("table_schema" = 'public' AND "table_name" = 'crm_interactions') OR ("table_schema" = 'public' AND "table_name" = 'paciente_exames')
